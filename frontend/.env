# Frontend Environment Variables
# React only reads variables that start with REACT_APP_

# Backend API URL
# For local development:
REACT_APP_API_URL=https://vts-codingplatform-production.up.railway.app/

# For production, update this to your Railway backend URL:
# REACT_APP_API_URL=https://your-backend.railway.app/api

# Frontend Environment
REACT_APP_ENV=development

# Maximum violations allowed (should match backend MAX_VIOLATIONS)
REACT_APP_MAX_VIOLATIONS=3
#WDS_ALLOWED_HOSTS=localhost