# Frontend Environment Variables
# React only reads variables that start with REACT_APP_

# Backend API URL
# Vercel production: same-origin /api (see vercel.json → AWS backend)
REACT_APP_API_URL=http://localhost:5000/api

# For local dev without proxy, you can use:
# REACT_APP_API_URL=http://localhost:5000/api

# Frontend Environment
REACT_APP_ENV=development

# Maximum violations allowed (should match backend MAX_VIOLATIONS)
REACT_APP_MAX_VIOLATIONS=3
#WDS_ALLOWED_HOSTS=localhost
